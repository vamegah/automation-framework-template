{
  "name": "selenium-agent-mcp-starter",
  "version": "1.0.0",
  "scripts": {
    "test": "mocha -r ts-node/register --timeout 30000 tests/**/*.spec.ts",
    "lint": "eslint . --ext .ts",
    "build": "tsc",
    "accessibility:index": "node scripts/aggregate-accessibility.cjs",
    "enterprise:run": "npx ts-node --project tsconfig.json scripts/run-enterprise-agent.ts",
    "test:enterprise": "npx ts-node --project tsconfig.json scripts/verify-enterprise.ts"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/selenium-webdriver": "^4.1.21",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "chai": "^4.5.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "selenium-webdriver": "^4.17.0"
  }
}
