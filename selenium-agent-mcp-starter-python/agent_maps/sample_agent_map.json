{
  "tasks": [
    {
      "name": "User Login",
      "url": "https://demo.nopcommerce.com/login",
      "actions": [
        { "type": "login", "username": "${NOPCOMMERCE_USERNAME}", "password": "${NOPCOMMERCE_PASSWORD}" },
        { "type": "assertText", "value": "Login was unsuccessful" }
      ]
    },
    {
      "name": "Login Page Smoke",
      "url": "https://demo.nopcommerce.com/login",
      "actions": [
        { "type": "navigate", "url": "https://demo.nopcommerce.com/login" },
        { "type": "assertText", "value": "Welcome, Please Sign In!" }
      ]
    }
  ]
}
