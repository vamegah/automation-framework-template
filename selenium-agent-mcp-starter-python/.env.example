BASE_URL=https://www.saucedemo.com
BROWSER=chrome
HEADLESS=false
IMPLICIT_WAIT=5
EXPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# Negative-path credentials used by invalid-login coverage
SAUCEDEMO_USERNAME=invalid_user
SAUCEDEMO_PASSWORD=wrong-password

# Positive-path credentials can be provided directly or through AWS Secrets Manager
SAUCEDEMO_STANDARD_USERNAME=standard_user
SAUCEDEMO_STANDARD_PASSWORD=secret_sauce

# Enable live AWS Secrets Manager resolution when the environment has valid AWS credentials
AWS_SECRET_INTEGRATION_ENABLED=false
AWS_REGION=us-east-1
VAULT_SECRET_INTEGRATION_ENABLED=false
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT_POINT=secret

# Option 1: reference a single JSON secret with fields
SAUCEDEMO_STANDARD_USERNAME_SECRET_ID=
SAUCEDEMO_STANDARD_USERNAME_SECRET_FIELD=username
SAUCEDEMO_STANDARD_PASSWORD_SECRET_ID=
SAUCEDEMO_STANDARD_PASSWORD_SECRET_FIELD=password

# Option 2: use aws-sm://secret-id#field references directly
SAUCEDEMO_STANDARD_USERNAME_SECRET_REF=
SAUCEDEMO_STANDARD_PASSWORD_SECRET_REF=

# Jira live integration
JIRA_LIVE_INTEGRATION_ENABLED=false
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_ACCOUNT_ID=

# Slack live integration
SLACK_LIVE_INTEGRATION_ENABLED=false
SLACK_WEBHOOK_URL=

# Datadog live integration
DATADOG_LIVE_INTEGRATION_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Splunk live integration
SPLUNK_LIVE_INTEGRATION_ENABLED=false
SPLUNK_BASE_URL=
SPLUNK_HEC_TOKEN=

# CloudWatch live integration
CLOUDWATCH_LIVE_INTEGRATION_ENABLED=false
