{
  "tasks": [
    {
      "name": "User Login",
      "url": "/web/index.php/auth/login",
      "actions": [
        { "type": "login", "username": "${ORANGEHRM_USERNAME}", "password": "${ORANGEHRM_PASSWORD}" },
        { "type": "assertUrl", "url": "/dashboard" }
      ]
    },
    {
      "name": "Dashboard Smoke",
      "url": "/web/index.php/dashboard/index",
      "actions": [
        { "type": "navigate", "url": "/web/index.php/dashboard/index" },
        { "type": "assertUrl", "url": "/dashboard" }
      ]
    }
  ]
}
